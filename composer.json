{
    "name": "nabilaahmed/laravel-postman-exporter",
    "description": "Automatically export and sync Laravel API routes to Postman Collections",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Nabila Ahmed",
            "email": "nabilashabban2000@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0|^11.0",
        "illuminate/console": "^10.0|^11.0",
        "illuminate/http": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "NabilaAhmed\\PostmanExporter\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "NabilaAhmed\\PostmanExporter\\PostmanExporterServiceProvider"
            ]
        }
    }
}
